{
  "name": "ruh-imperium-vercel",
  "version": "1.0.0",
  "private": true,

  "scripts": {
    "start": "cd backend && npm start",
    "dev": "cd backend && npm run dev",
    "install": "cd backend && npm install",
    "build": "npm --prefix frontend run build",
    "postinstall": "pnpm --filter frontend install",
    "sync:products": "echo skip-sync",
    "import:catalog": "node scripts/import-raahi-catalog.js && node scripts/rebrand-catalog.js && npm run sync:products",
    "predeploy": "npm run sync:products"
  },
  "dependencies": {
    "mongodb": "^7.1.1",
    "nodemailer": "^8.0.5"
  }
}
